# Translator Everywhere — backend env (slice 6a).
# Copy to ~/.translator-everywhere/deploy.env on the VPS (chmod 600).
# NEVER commit a real .env — only this placeholder example.

# Required.
DATABASE_URL=postgres://te_app:CHANGE_ME@127.0.0.1:5432/translator_everywhere?sslmode=disable
JWT_SECRET=CHANGE_ME_long_random_hex_used_to_sign_session_jwts

# Optional — default to the public CONFIG.md identifiers; override only for staging.
# APPLE_AUD=com.cdcupt.translator-everywhere
# APPLE_ISS=https://appleid.apple.com
# GOOGLE_AUD=328818408791-641sqb2v2smjgjud26e87j7rhnfo0uem.apps.googleusercontent.com
# PORT=8110

# Sign in with Apple — WEB OAuth flow.
# APPLE_SERVICES_ID is the Apple Services ID (the OAuth client_id) and is also
# the id_token audience. The placeholder below is the default; set the real
# Services ID once provisioned. The redirect_uri MUST match what is registered
# on the Services ID in the Apple Developer portal.
# APPLE_SERVICES_ID=com.cdcupt.translator-everywhere.web
# APPLE_TEAM_ID=NK3U2C365Z
# APPLE_REDIRECT_URI=https://api.translator.daichenlab.com/auth/apple/callback
# APP_CALLBACK_SCHEME=translator-everywhere
#
# SECRETS — never commit real values. The .p8 key id, plus the key itself
# supplied EITHER inline as the PEM contents OR via a file path.
# APPLE_KEY_ID=CHANGE_ME_10CHAR_KEY_ID
# APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...p8 contents...\n-----END PRIVATE KEY-----\n"
# APPLE_PRIVATE_KEY_FILE=/run/secrets/apple_authkey.p8
