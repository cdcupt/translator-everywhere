# nothing secret lives here; key stays in ~/.openai/keys.env

# macOS app (/macos): the .xcodeproj is generated from project.yml by xcodegen.
# Commit project.yml + Sources only; never the generated project or build output.
/macos/*.xcodeproj/
/macos/.build/
/macos/build/
/macos/DerivedData/
# xcodegen-generated Info.plist (from project.yml `info:` block) is build output.
/macos/Generated/
# Distribution artifacts (signed .app, notarization zip, release .dmg) are never committed.
/macos/*.dmg
/macos/*.app
/macos/*.zip
# The DMG build writes releases under macos/dist/ — keep the whole dir out.
/macos/dist/
.DS_Store

# Backend (/server): never commit real envs or build output. Only .env.example.
/server/.env
/server/.env.*
!/server/.env.example
/server/server
/server/bin/
