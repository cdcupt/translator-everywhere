#!/usr/bin/env bash
# te — terminal translator across 130+ languages (multi-language; EN<->ZH stays the default).
# Two engines: AI (OpenAI, default — high quality) and Google Translate (free, no key).
#
#   te                 translate the clipboard into your target (auto-detect source)
#   te <text...>       translate the given text
#   echo x | te        translate piped stdin
#   te -f en -t ja x   translate x from English to Japanese
#   te -t fr <text>    translate into French (source auto-detected)
#   te -l [query]      list / search the language catalog (codes + names)
#   te --detect <text> print only the detected source language
#   te -g <text>       use the free Google Translate engine instead of AI
#   te -e <text>       (AI only) also show a short explanation / pinyin / usage note
#   te -i              interactive REPL (one line at a time, blank line or Ctrl-D quits)
#   te -c [image]      capture a screen region (or translate an image file): OCR + translate (AI, macOS)
#   te --popup         read stdin, translate, show a macOS dialog + copy result (Quick Actions)
#
# Languages:
#   -f, --from <code>  source language code (default: $TE_FROM, else "auto")
#   -t, --to   <code>  target language code (default: $TE_TO, else "zh-CN")
#   Codes come from languages.tsv (shipped next to te); run `te -l` to browse them.
#   Same-language guard: with an auto source, if the text is already in your target
#   language the translation flips to the secondary ($TE_SECONDARY, default "en") —
#   so the classic EN<->ZH two-way flow is preserved.
#
# Config (env or ~/.te/config — sourced if present):
#   TE_FROM            default source code (default: auto)
#   TE_TO              default target code (default: zh-CN)
#   TE_SECONDARY       same-language fallback target (default: en)
#   TE_ENGINE          openai | google   (default: openai)
#   TE_MODEL           model id (default: gpt-4o-mini)
#   OPENAI_API_KEY     required for the AI engine (or ~/.openai/keys.env)
#   TE_KEY_FILE        path to a file exporting OPENAI_API_KEY (default: ~/.openai/keys.env)
set -euo pipefail

die() { printf 'te: %s\n' "$1" >&2; exit 1; }

# --- load translation prefs (~/.te/config) ----------------------------------
# Sourced before defaults so the config can set TE_FROM/TE_TO/TE_SECONDARY (and
# engine/model) without env vars. CLI flags, parsed later, still win.
TE_CONFIG="${TE_CONFIG:-$HOME/.te/config}"
if [[ -f "$TE_CONFIG" ]]; then
  set -a; . "$TE_CONFIG"; set +a
fi

TE_ENGINE="${TE_ENGINE:-openai}"
TE_MODEL="${TE_MODEL:-gpt-4o-mini}"
TE_FROM="${TE_FROM:-auto}"
TE_TO="${TE_TO:-zh-CN}"
TE_SECONDARY="${TE_SECONDARY:-en}"
TE_KEY_FILE="${TE_KEY_FILE:-$HOME/.openai/keys.env}"
EXPLAIN=0
POPUP=0
INTERACTIVE=0
CAPTURE=0
LIST=0
DETECT=0

# Print the contiguous comment header (everything from line 2 until the first
# non-comment line), stripping the leading "# ". Robust to header edits.
usage() {
  awk 'NR==1{next} /^#/{sub(/^# ?/,""); print; next} {exit}' "$0"
  exit "${1:-0}"
}

# --- locate the shared language catalog -------------------------------------
# `te` is run through a PATH symlink ($0 is the symlink), so follow it to the
# real script and read languages.tsv sitting beside it.
resolve_real() {
  local src="$1" target
  while [[ -L "$src" ]]; do
    target="$(readlink "$src")"
    if [[ "$target" == /* ]]; then src="$target"; else src="$(cd "$(dirname "$src")" && pwd)/$target"; fi
  done
  printf '%s' "$src"
}
SCRIPT_REAL="$(resolve_real "${BASH_SOURCE[0]:-$0}")"
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_REAL")" && pwd)"
LANG_TSV="$SCRIPT_DIR/languages.tsv"

require_tsv() {
  [[ -f "$LANG_TSV" ]] || die "language catalog not found (expected languages.tsv next to te at $LANG_TSV)"
}

# Print column `col` (1=code 2=englishName 3=endonym 4=googleCode 5=aiName) for
# the row whose code == `$1`. Exit 1 (no output) when the code is unknown.
lookup_lang() {
  awk -F'\t' -v code="$1" -v col="$2" \
    'NR>1 && $1==code { print $col; f=1; exit } END { if(!f) exit 1 }' "$LANG_TSV"
}
validate_code()   { lookup_lang "$1" 1 >/dev/null 2>&1; }
googlecode_for()  { lookup_lang "$1" 4; }
name_for()        { lookup_lang "$1" 2; }
endonym_for()     { lookup_lang "$1" 3; }
ainame_for()      { lookup_lang "$1" 5; }

# Map a Google detected-source code (column 4, e.g. iw/jw/zh-CN) back to the
# canonical code (column 1). No output (exit 1) when nothing matches.
googlecode_to_code() {
  awk -F'\t' -v gc="$1" \
    'NR>1 && $4==gc { print $1; f=1; exit } END { if(!f) exit 1 }' "$LANG_TSV"
}

# List / search the catalog: code, English name, native name. An empty query
# lists everything; otherwise case-insensitive substring over code/names/aliases.
list_languages() {
  local q="${1:-}"
  printf '%-9s %-26s %s\n' "CODE" "LANGUAGE" "NATIVE"
  awk -F'\t' -v q="$q" '
    NR==1 { next }
    {
      hay = tolower($1 " " $2 " " $3 " " $6)
      if (q == "" || index(hay, tolower(q))) printf "%-9s %-26s %s\n", $1, $2, $3
    }
  ' "$LANG_TSV"
}

# Validate the resolved language codes; a bad secondary silently falls back to en.
validate_langs() {
  if [[ "$TE_FROM" != "auto" ]]; then
    validate_code "$TE_FROM" || die "unknown source language: '$TE_FROM' (try: te -l)"
  fi
  validate_code "$TE_TO" || die "unknown target language: '$TE_TO' (try: te -l)"
  validate_code "$TE_SECONDARY" || TE_SECONDARY="en"
}

# --- load API key (AI engine only) ------------------------------------------
load_key() {
  if [[ -z "${OPENAI_API_KEY:-}" && -f "$TE_KEY_FILE" ]]; then
    set -a; . "$TE_KEY_FILE"; set +a
  fi
  [[ -n "${OPENAI_API_KEY:-}" ]] || die "OPENAI_API_KEY not set (looked in $TE_KEY_FILE) — or use -g for free Google"
}

# --- detect Chinese (cheap Han-script test; no network) ---------------------
is_chinese() {
  printf '%s' "$1" | perl -CSD -0777 -ne 'exit(/\p{Han}/ ? 0 : 1)' 2>/dev/null
}

# --- raw Google Translate call (returns the JSON body, or non-zero) ----------
google_call() {
  local text="$1" tl="$2" sl="$3" resp attempt
  resp=""
  for attempt in 1 2 3; do
    if resp=$(curl -sS --max-time 30 --retry 2 --retry-connrefused -G \
      "https://translate.googleapis.com/translate_a/single" \
      --data-urlencode "client=gtx" \
      --data-urlencode "sl=$sl" \
      --data-urlencode "tl=$tl" \
      --data-urlencode "dt=t" \
      --data-urlencode "q=$text" 2>/dev/null); then
      break
    fi
    resp=""
    sleep 1
  done
  [[ -n "$resp" ]] || return 1
  printf '%s' "$resp"
}

# Detected source as a Google code (the response's .[2] field), or empty.
detect_googlecode() {
  local resp; resp="$(google_call "$1" "en" "auto")" || return 1
  jq -r '.[2] // empty' <<<"$resp"
}

# Canonical detected-source code for `text`. Han script short-circuits to zh-CN
# (no network — keeps the common EN<->ZH path key/jq-free); otherwise Google's
# detected-source mapped back to a catalog code. Empty when detection fails.
detect_canonical() {
  local text="$1" gc canon
  if is_chinese "$text"; then printf 'zh-CN'; return; fi
  gc="$(detect_googlecode "$text" 2>/dev/null || true)"
  [[ -n "$gc" ]] || return 0
  canon="$(googlecode_to_code "$gc" 2>/dev/null || true)"
  printf '%s' "${canon:-$gc}"
}

# --- same-language guard: resolve the effective target for `text` ------------
# Mirrors the app's PairResolver: only an auto source with a distinct secondary
# can flip, and only when the detected source equals the target. Detection is
# skipped whenever it can't change the answer (non-Han text + a zh-CN target can
# never be Chinese), so the default config stays network-free for that path.
resolve_target() {
  local text="$1" to_code="$TE_TO" detected
  if [[ "$TE_FROM" == "auto" && "$TE_SECONDARY" != "$TE_TO" ]]; then
    if is_chinese "$text" || [[ "$TE_TO" != "zh-CN" ]]; then
      detected="$(detect_canonical "$text")"
      [[ -n "$detected" && "$detected" == "$TE_TO" ]] && to_code="$TE_SECONDARY"
    fi
  fi
  printf '%s' "$to_code"
}

# --- free Google Translate engine (no key) ----------------------------------
google_translate() {
  local text="$1" to_code="$2" tl sl resp out
  tl="$(googlecode_for "$to_code")"; tl="${tl:-$to_code}"
  if [[ "$TE_FROM" == "auto" ]]; then sl="auto"; else sl="$(googlecode_for "$TE_FROM")"; sl="${sl:-$TE_FROM}"; fi
  resp="$(google_call "$text" "$tl" "$sl")" || die "network error calling Google Translate (no response after retries)"
  out=$(jq -r '[.[0][]?[0] // empty] | join("")' <<<"$resp" 2>/dev/null)
  [[ -n "$out" ]] || die "Google Translate returned nothing (unexpected response)"
  printf '%s\n' "$out"
}

# --- shared OpenAI chat call -------------------------------------------------
# Reads the JSON request body from a FILE (not an argument) and POSTs it with
# --data-binary, so large vision payloads never hit the command-line ARG_MAX.
openai_chat() {
  local body_file="$1" resp out err attempt
  resp=""
  for attempt in 1 2 3; do
    if resp=$(curl -sS --max-time 60 \
      --retry 2 --retry-connrefused \
      https://api.openai.com/v1/chat/completions \
      -H "Authorization: Bearer $OPENAI_API_KEY" \
      -H "Content-Type: application/json" \
      --data-binary @"$body_file" 2>/dev/null); then
      break
    fi
    resp=""
    sleep 1
  done
  [[ -n "$resp" ]] || die "network error calling OpenAI (no response after retries)"

  out=$(jq -r '.choices[0].message.content // empty' <<<"$resp")
  if [[ -z "$out" ]]; then
    err=$(jq -r '.error.message // "unknown API error"' <<<"$resp")
    die "$err"
  fi
  printf '%s\n' "$out"
}

# --- AI engine (OpenAI); translates `text` into `to_code` -------------------
openai_translate() {
  local text="$1" to_code="$2" sys body target_name source_clause from_name
  target_name="$(ainame_for "$to_code")"
  target_name="${target_name:-$(name_for "$to_code")}"
  target_name="${target_name:-$to_code}"
  if [[ "$TE_FROM" == "auto" ]]; then
    source_clause="Detect the input language."
  else
    from_name="$(ainame_for "$TE_FROM")"; from_name="${from_name:-$(name_for "$TE_FROM")}"; from_name="${from_name:-$TE_FROM}"
    source_clause="The input is in $from_name."
  fi

  sys="You are a precise translator. $source_clause Translate the input into natural, \
idiomatic $target_name. Preserve meaning, tone and any technical terms. Do not add quotes or commentary."
  if [[ "$EXPLAIN" == 1 ]]; then
    sys+=" After the translation, add a line starting with '— ' giving a brief note: \
for a single word or short term include part of speech and (where relevant) romanization and one short usage example; \
for a sentence, note any nuance worth knowing. Keep the note to one or two short lines."
  else
    sys+=" Output ONLY the translation, nothing else."
  fi

  body="${TMPDIR:-/tmp}/te_body_$$.json"
  jq -n --arg model "$TE_MODEL" --arg sys "$sys" --arg user "$text" \
    '{model:$model, temperature:0.2,
      messages:[{role:"system",content:$sys},{role:"user",content:$user}]}' > "$body"
  openai_chat "$body"
  rm -f "$body" 2>/dev/null || true
}

# --- AI vision engine (OpenAI): OCR + translate the text in an image --------
openai_translate_image() {
  local img="$1" small b64 body sys target_name secondary_name
  target_name="$(ainame_for "$TE_TO")"; target_name="${target_name:-$(name_for "$TE_TO")}"; target_name="${target_name:-$TE_TO}"
  secondary_name="$(ainame_for "$TE_SECONDARY")"; secondary_name="${secondary_name:-$(name_for "$TE_SECONDARY")}"; secondary_name="${secondary_name:-$TE_SECONDARY}"
  # Downscale a copy (sips is built into macOS) so the base64 payload stays
  # reasonable; OCR stays accurate at ~1600px on the long edge.
  small="${TMPDIR:-/tmp}/te_img_$$.png"
  if /usr/bin/sips -Z 1600 "$img" --out "$small" >/dev/null 2>&1; then img="$small"; fi

  b64="${TMPDIR:-/tmp}/te_b64_$$.txt"
  base64 < "$img" | tr -d '\n' > "$b64"

  sys="You are an OCR and translation tool. Read all text visible in the image, \
in natural reading order, then translate it into natural, idiomatic $target_name. \
If the text is already in $target_name, translate it into $secondary_name instead. \
Preserve meaning, tone and any technical terms. Output ONLY the translation — no original text, no commentary."

  body="${TMPDIR:-/tmp}/te_body_$$.json"
  # --rawfile reads the (large) base64 from a file, avoiding jq's ARG_MAX limit.
  jq -n --arg model "$TE_MODEL" --arg sys "$sys" --rawfile b64 "$b64" \
    '{model:$model, temperature:0.2,
      messages:[{role:"system",content:$sys},
                {role:"user",content:[{type:"text",text:"Translate the text in this image."},
                                      {type:"image_url",image_url:{url:("data:image/png;base64,"+$b64)}}]}]}' > "$body"
  openai_chat "$body"
  rm -f "$small" "$b64" "$body" 2>/dev/null || true
}

# --- translate dispatch ------------------------------------------------------
# translate_to: translate with an already-resolved target (no guard re-run).
translate_to() {
  local text="$1" to_code="$2"
  [[ -n "${text//[[:space:]]/}" ]] || die "nothing to translate"
  if [[ "$TE_ENGINE" == "google" ]]; then
    google_translate "$text" "$to_code"
  else
    openai_translate "$text" "$to_code"
  fi
}
# translate: apply the same-language guard, then translate.
translate() {
  local text="$1"
  [[ -n "${text//[[:space:]]/}" ]] || die "nothing to translate"
  translate_to "$text" "$(resolve_target "$text")"
}

# --- pretty terminal output -------------------------------------------------
print_result() {
  local src="$1" out="$2" dim cyan reset
  if [[ -t 1 ]]; then
    dim=$'\033[2m'; cyan=$'\033[36m'; reset=$'\033[0m'
  else
    dim=""; cyan=""; reset=""
  fi
  # Echo the source dimmed only when it didn't come from explicit args on a tty,
  # so the user can see what was translated (e.g. from clipboard).
  if [[ -n "$src" ]]; then
    printf '%s%s%s\n' "$dim" "$src" "$reset"
  fi
  printf '%s%s%s\n' "$cyan" "$out" "$reset"
}

# --- macOS dialog showing a result (used by --popup) ------------------------
show_popup() {
  local body="$1" title="$2"
  /usr/bin/osascript - "$body" "$title" <<'OSA' >/dev/null 2>&1 || true
on run argv
  display dialog (item 1 of argv) with title (item 2 of argv) buttons {"OK"} default button "OK"
end run
OSA
}

# --- screen-region capture (or image file) -> OCR + translate (AI vision) ---
# Prints the translation on success. Distinct exit statuses so the caller can
# tell apart a clean cancel from a real failure:
#   0  -> success (translation on stdout)
#   2  -> user cancelled the interactive capture (nothing to do)
#   1  -> real error: a `die` inside (bad path, network/API failure) propagates 1.
capture_translate() {
  local img="${1:-}" shot rc
  if [[ -n "$img" ]]; then
    [[ -f "$img" ]] || die "not a readable image file: $img"
    openai_translate_image "$img"
    return 0
  fi
  shot="${TMPDIR:-/tmp}/te_capture_$$.png"
  # interactive region selection; Esc cancels and leaves no/empty file
  /usr/sbin/screencapture -i -x "$shot" 2>/dev/null || true
  if [[ ! -s "$shot" ]]; then
    rm -f "$shot" 2>/dev/null || true
    return 2
  fi
  openai_translate_image "$shot"; rc=$?
  rm -f "$shot" 2>/dev/null || true
  return "$rc"
}

# --- parse flags ------------------------------------------------------------
args=()
while [[ $# -gt 0 ]]; do
  case "$1" in
    -e|--explain) EXPLAIN=1; shift ;;
    -g|--google) TE_ENGINE="google"; shift ;;
    -a|--ai|--openai) TE_ENGINE="openai"; shift ;;
    --engine) TE_ENGINE="${2:?--engine needs openai|google}"; shift 2 ;;
    -f|--from) TE_FROM="${2:?-f needs a language code}"; shift 2 ;;
    -t|--to) TE_TO="${2:?-t needs a language code}"; shift 2 ;;
    -l|--languages) LIST=1; shift ;;
    --detect) DETECT=1; shift ;;
    -i|--interactive) INTERACTIVE=1; shift ;;
    -c|--capture) CAPTURE=1; shift ;;
    --popup) POPUP=1; shift ;;
    -m|--model) TE_MODEL="${2:?-m needs a model}"; shift 2 ;;
    -h|--help) usage 0 ;;
    --) shift; args+=("$@"); break ;;
    -*) die "unknown option: $1 (try -h)" ;;
    *) args+=("$1"); shift ;;
  esac
done

# The catalog drives every mode now — fail early and clearly if it's missing.
require_tsv

# --- list / search the catalog (no engine, no key) --------------------------
if [[ "$LIST" == 1 ]]; then
  list_languages "${args[*]:-}"
  exit 0
fi

# Screen capture uses the AI vision engine (OCR + translate in one call).
[[ "$CAPTURE" == 1 ]] && TE_ENGINE="openai"

case "$TE_ENGINE" in
  openai|google) ;;
  *) die "unknown engine: $TE_ENGINE (use openai or google)" ;;
esac
# Explanation notes are an AI-only capability.
[[ "$TE_ENGINE" == "google" ]] && EXPLAIN=0

validate_langs

# --- detect-only mode: print the source language and stop -------------------
if [[ "$DETECT" == 1 ]]; then
  if [[ ${#args[@]} -gt 0 ]]; then
    dtext="${args[*]}"
  elif [[ ! -t 0 ]]; then
    dtext="$(cat)"
  else
    dtext="$(pbpaste 2>/dev/null || true)"
  fi
  [[ -n "${dtext//[[:space:]]/}" ]] || die "nothing to detect — pass text, pipe stdin, or copy to the clipboard"
  code="$(detect_canonical "$dtext")"
  [[ -n "$code" ]] || die "could not detect the source language (network/jq unavailable?)"
  dname="$(name_for "$code" 2>/dev/null || true)"
  if [[ -n "$dname" ]]; then printf '%s (%s)\n' "$dname" "$code"; else printf '%s\n' "$code"; fi
  exit 0
fi

# The OpenAI key is only needed for the AI engine (Google and its key-free path
# never touch it). Load it lazily, and only then.
if [[ "$TE_ENGINE" == "openai" ]]; then load_key; fi

# --- capture mode (macOS): screen region or image file -> OCR + translate ---
if [[ "$CAPTURE" == 1 ]]; then
  errf="${TMPDIR:-/tmp}/te_err_$$.txt"; rc=0
  out="$(capture_translate "${args[0]:-}" 2>"$errf")" || rc=$?
  cap_to="$(endonym_for "$TE_TO" 2>/dev/null || true)"; cap_to="${cap_to:-$TE_TO}"
  if [[ "$rc" -eq 2 ]]; then            # user cancelled the capture — quiet exit
    rm -f "$errf" 2>/dev/null || true
    exit 0
  fi
  if [[ "$rc" -ne 0 ]]; then            # real error — surface it, don't fake success
    err_msg="$(cat "$errf" 2>/dev/null)"; rm -f "$errf" 2>/dev/null || true
    err_msg="${err_msg:-te: capture failed}"
    if [[ "$POPUP" == 1 ]]; then show_popup "$err_msg" "翻译 · 截图 → $cap_to (错误)"; fi
    printf '%s\n' "$err_msg" >&2
    exit 1
  fi
  rm -f "$errf" 2>/dev/null || true
  if [[ -z "${out//[[:space:]]/}" ]]; then   # capture worked but no text recognised
    if [[ "$POPUP" == 1 ]]; then show_popup "未识别到文字" "翻译 · 截图 → $cap_to"; fi
    exit 0
  fi
  if [[ "$POPUP" == 1 ]]; then
    printf '%s' "$out" | pbcopy 2>/dev/null || true
    show_popup "$out" "翻译 · 截图 → $cap_to"
  else
    print_result "" "$out"
  fi
  exit 0
fi

# --- popup mode (macOS Quick Action): stdin -> dialog + clipboard -----------
if [[ "$POPUP" == 1 ]]; then
  text="$(cat)"
  eff_to="$(resolve_target "$text")"
  out="$(translate_to "$text" "$eff_to")"
  printf '%s' "$out" | pbcopy 2>/dev/null || true
  to_disp="$(endonym_for "$eff_to" 2>/dev/null || true)"; to_disp="${to_disp:-$eff_to}"
  if [[ "$TE_ENGINE" == "google" ]]; then popup_title="翻译 · Google → $to_disp"; else popup_title="翻译 · AI → $to_disp"; fi
  show_popup "$out" "$popup_title"
  exit 0
fi

# --- interactive REPL -------------------------------------------------------
if [[ "$INTERACTIVE" == 1 ]]; then
  printf 'te interactive — type text, blank line or Ctrl-D to quit\n' >&2
  while IFS= read -r -p "› " line || [[ -n "${line:-}" ]]; do
    [[ -z "${line//[[:space:]]/}" ]] && break
    print_result "" "$(translate "$line")"
  done
  exit 0
fi

# --- one-shot: args > stdin > clipboard -------------------------------------
src=""
if [[ ${#args[@]} -gt 0 ]]; then
  text="${args[*]}"
elif [[ ! -t 0 ]]; then
  text="$(cat)"
else
  text="$(pbpaste 2>/dev/null || true)"
  src="$text"   # show what came off the clipboard
  [[ -n "${text//[[:space:]]/}" ]] || die "clipboard is empty — copy some text, or run: te <text>"
fi

print_result "$src" "$(translate "$text")"
